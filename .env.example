# Required: comma-separated Mail.app account names
# Run `mail-app-cli accounts list` to see available accounts
MAIL_ACCOUNTS="Gmail,iCloud"

# Mailbox to fetch from (default: INBOX)
MAIL_MAILBOX="INBOX"

# How many days back to look for emails (default: 1)
MAIL_SINCE_DAYS=1

# Required: path to your Obsidian vault root
VAULT_PATH="/Users/you/path/to/Your Vault"

# Subdirectory for summary output (default: sources)
SOURCES_DIR="sources"

# LLM command template: {input} and {output} are replaced with temp file paths.
# Bring your own CLI — any tool that reads a prompt file and writes a response file.
# LLM_CMD="claude -p --model claude-haiku-4-5-20251001 --effort medium --no-session-persistence < {input} > {output}"
# LLM_CMD="codex e -m gpt-5.4-mini --skip-git-repo-check --ephemeral -c model_reasoning_effort='\"low\"' -o {output} < {input}"
# LLM_CMD="pi -p --model gpt-5.4-mini --provider openai-codex --thinking medium --no-session --no-extensions < {input} > {output}"
