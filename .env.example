# Required: comma-separated Mail.app account names
# Run the install.sh script to see available accounts
MAIL_ACCOUNTS="Gmail,iCloud"

# How many days back to look for emails (default: 1)
MAIL_SINCE_DAYS=1

# Required: path to your Obsidian vault root
VAULT_PATH="/Users/you/path/to/Your Vault"

# Subdirectory for summary output (default: sources)
OUTPUT_DIR="sources"

# LLM command: reads prompt from stdin, writes summary to stdout.
# LLM_CMD="claude -p --model claude-sonnet-4-6 --effort high --no-session-persistence"
# LLM_CMD="claude -p --model claude-haiku-4-5-20251001 --effort medium --no-session-persistence"
# LLM_CMD="codex e -m gpt-5.4-mini --skip-git-repo-check --ephemeral -o /dev/stdout"
