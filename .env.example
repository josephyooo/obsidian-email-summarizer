# Required: comma-separated Mail.app account names
# Run `mail-app-cli accounts list` to see available accounts
MAIL_ACCOUNTS="Gmail,iCloud"

# Mailbox to fetch from (default: INBOX)
MAIL_MAILBOX="INBOX"

# How many days back to look for emails (default: 1)
MAIL_SINCE_DAYS=1

# Required: path to your Obsidian vault root
VAULT_PATH="/Users/you/path/to/Your Vault"

# Subdirectory for summary output (default: sources)
SOURCES_DIR="sources"

# LLM command: receives prompt on stdin, writes summary to stdout
# LLM_CMD="claude --model claude-haiku-4-5-20251001 --effort medium --no-session-persistence -p"
# LLM_CMD="pi --model gpt-5.4-mini --provider openai-codex --thinking medium --no-session --no-themes -p"
